// secrets.h.example — Template for WiFi credentials
// ─────────────────────────────────────────────────
// 1. Copy this file and rename it to:  secrets.h
// 2. Fill in your actual credentials below
// 3. secrets.h is listed in .gitignore — it will NEVER be committed to Git
//
// This pattern (secrets.h) is the standard Arduino community approach
// for keeping credentials out of public repositories.

#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID     "your_wifi_network_name"
#define WIFI_PASSWORD "your_wifi_password"

#endif
